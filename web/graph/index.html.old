<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GraphRAG 3D Hierarchy - Full Dataset</title>
    <style>
        body {
            margin: 0;
            background: #0a0e1a;
            font-family: 'Arial', sans-serif;
            overflow: hidden;
        }

        #3d-graph {
            width: 100%;
            height: 100vh;
        }

        #info-panel {
            position: absolute;
            top: 20px;
            left: 20px;
            padding: 20px;
            background: rgba(15, 20, 35, 0.95);
            border: 1px solid rgba(100, 200, 255, 0.3);
            border-radius: 10px;
            color: #e0e0e0;
            max-width: 350px;
            max-height: 80vh;
            overflow-y: auto;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        #controls {
            position: absolute;
            top: 20px;
            right: 20px;
            padding: 15px;
            background: rgba(15, 20, 35, 0.95);
            border: 1px solid rgba(100, 200, 255, 0.3);
            border-radius: 10px;
            color: #e0e0e0;
            backdrop-filter: blur(10px);
            z-index: 1000;
        }

        #loading {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #00ffff;
            font-size: 24px;
            text-align: center;
            z-index: 2000;
        }

        .spinner {
            border: 3px solid rgba(0, 255, 255, 0.1);
            border-radius: 50%;
            border-top: 3px solid #00ffff;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            margin: 5px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .dataset-selector {
            margin-bottom: 15px;
            padding: 10px;
            background: rgba(100, 200, 255, 0.1);
            border-radius: 5px;
        }

        .dataset-info {
            color: #00ffff;
            font-size: 12px;
            margin-top: 10px;
        }

        .search-box {
            width: 100%;
            padding: 8px;
            margin: 10px 0;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(100, 200, 255, 0.3);
            border-radius: 5px;
            color: white;
        }

        .stats {
            margin-top: 15px;
            padding: 10px;
            background: rgba(0, 255, 255, 0.05);
            border-radius: 5px;
            font-size: 12px;
        }

        .level-indicator {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            margin-left: 5px;
        }

        .level-0 { background: rgba(255, 100, 100, 0.3); }
        .level-1 { background: rgba(100, 255, 100, 0.3); }
        .level-2 { background: rgba(100, 100, 255, 0.3); }
        .level-3 { background: rgba(255, 255, 100, 0.3); }
    </style>
</head>
<body>
    <div id="loading">
        <div>Loading Full Knowledge Graph...</div>
        <div class="spinner"></div>
        <div id="loading-status">Initializing...</div>
    </div>

    <div id="3d-graph"></div>

    <div id="info-panel" style="display: none;">
        <h2 id="node-title">GraphRAG 3D Hierarchy</h2>
        <p id="node-description">Click on nodes to explore the knowledge graph</p>
        <div id="node-details"></div>
        <div id="node-stats" class="stats"></div>
    </div>

    <div id="controls">
        <div class="dataset-selector">
            <label>Dataset: </label>
            <select id="dataset-select" style="padding: 5px; background: #1a1f2e; color: white; border: 1px solid #00ffff;">
                <option value="full">Full (37,924 entities)</option>
                <option value="standard">Standard (12,287 entities)</option>
            </select>
            <div class="dataset-info" id="dataset-info">
                Loading full dataset with all books and episodes
            </div>
        </div>

        <input type="text" class="search-box" placeholder="Search entities..." id="search-input">

        <button id="reset-view">Reset View</button>
        <button id="toggle-labels">Toggle Labels</button>
        <button id="expand-all">Expand All</button>
        <button id="collapse-all">Collapse All</button>

        <div class="stats">
            <div>Clusters: <span id="cluster-count">-</span></div>
            <div>Entities visible: <span id="entity-count">-</span></div>
            <div>Performance: <span id="fps">-</span> FPS</div>
        </div>
    </div>

    <script src="https://unpkg.com/three@0.150.1/build/three.min.js"></script>
    <script src="https://unpkg.com/3d-force-graph@1.71/dist/3d-force-graph.min.js"></script>
    <script>
        // Load the appropriate script based on dataset selection
        const datasetSelect = document.getElementById('dataset-select');
        const script = document.createElement('script');

        // Default to full dataset
        script.src = 'GraphRAG3D_Full.js';
        script.onerror = () => {
            // Fallback to standard if full doesn't exist yet
            script.src = 'GraphRAG3D_v2.js';
        };

        document.body.appendChild(script);

        // Handle dataset switching
        datasetSelect.addEventListener('change', (e) => {
            const confirmSwitch = confirm(`Switch to ${e.target.value} dataset? This will reload the page.`);
            if (confirmSwitch) {
                // Store selection
                localStorage.setItem('graphrag-dataset', e.target.value);
                location.reload();
            } else {
                // Revert selection
                e.target.value = localStorage.getItem('graphrag-dataset') || 'full';
            }
        });

        // Restore previous selection
        const savedDataset = localStorage.getItem('graphrag-dataset') || 'full';
        datasetSelect.value = savedDataset;
    </script>
</body>
</html>